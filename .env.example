API_PORT=4000
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=change-this-secret-in-production
VITE_API_URL=http://localhost:4000/api

# Supabase
# Project URL: Supabase Dashboard -> Project Settings -> API -> Project URL
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Лучше использовать service_role только на backend. Не добавляйте его в VITE_* переменные.
# Supabase Dashboard -> Project Settings -> API -> service_role secret
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Можно использовать anon key, если вы настроили RLS-политики. Для этого прототипа проще service_role.
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ML service
ML_SERVICE_URL=http://127.0.0.1:8001

# Разрешённые frontend-домены для CORS. Можно указывать несколько через запятую.
CLIENT_ORIGINS=http://localhost:5173,https://lab2-beryl.vercel.app,https://lab2-git-main-mineracs-projects.vercel.app,https://lab2-bny619abz-mineracs-projects.vercel.app

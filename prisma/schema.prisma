generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  autoOrders AutoOrder[]
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  category    String
  price       Float
  cost        Float?
  stock       Int      @default(0)
  minStock    Int      @default(10)
  maxStock    Int      @default(100)
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movements   StockMovement[]
  autoRules   AutoOrder[]
  orders      Order[]
  predictions DemandPrediction[]
}

model StockMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  type      MovementType
  note      String?
  createdAt DateTime @default(now())
}

model AutoOrder {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  triggerLevel Int
  orderQuantity Int
  isActive    Boolean  @default(true)
  lastTriggeredAt DateTime?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User?    @relation(fields: [createdBy], references: [id])
}

model Order {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  status      OrderStatus
  totalPrice  Float?
  orderedAt   DateTime @default(now())
  expectedDelivery DateTime?
  deliveredAt DateTime?
  externalId  String?
}

model DemandPrediction {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  predictedDate DateTime
  predictedQuantity Float
  modelVersion String
  createdAt  DateTime @default(now())

  @@unique([productId, predictedDate])
}

enum Role {
  ADMIN
  MANAGER
  VIEWER
}

enum MovementType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}
